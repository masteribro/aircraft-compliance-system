<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="001-initial-schema" author="compliance-system">
        <!-- Aircraft Table -->
        <createTable tableName="aircraft">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tail_number" type="varchar(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="aircraft_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="total_rows" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="seats_per_row" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Sensors Table -->
        <createTable tableName="sensors">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="aircraft_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_sensors_aircraft" 
                    references="aircraft(id)"/>
            </column>
            <column name="sensor_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="location_row" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="location_zone" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="sensor_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="last_heartbeat" type="timestamp">
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Detected Devices Table -->
        <createTable tableName="detected_devices">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="aircraft_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_devices_aircraft" 
                    references="aircraft(id)"/>
            </column>
            <column name="sensor_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_devices_sensor" 
                    references="sensors(id)"/>
            </column>
            <column name="mac_address" type="varchar(17)">
                <constraints nullable="false"/>
            </column>
            <column name="device_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="signal_strength" type="integer" defaultValue="-100">
                <constraints nullable="false"/>
            </column>
            <column name="estimated_row" type="integer">
            </column>
            <column name="confidence_score" type="decimal(3,2)" defaultValue="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="is_in_airplane_mode" type="boolean" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="detected_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_seen" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Cabin Activity Logs Table -->
        <createTable tableName="cabin_activity">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="aircraft_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_activity_aircraft" 
                    references="aircraft(id)"/>
            </column>
            <column name="activity_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="row_number" type="integer">
            </column>
            <column name="seat_number" type="varchar(5)">
            </column>
            <column name="activity_description" type="text">
            </column>
            <column name="severity" type="varchar(20)" defaultValue="INFO">
                <constraints nullable="false"/>
            </column>
            <column name="device_count" type="integer" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="recorded_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Alerts Table -->
        <createTable tableName="alerts">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="aircraft_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_alerts_aircraft" 
                    references="aircraft(id)"/>
            </column>
            <column name="alert_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="varchar(20)" defaultValue="MEDIUM">
                <constraints nullable="false"/>
            </column>
            <column name="row_number" type="integer">
            </column>
            <column name="device_count" type="integer" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValue="true">
                <constraints nullable="false"/>
            </column>
            <column name="crew_acknowledged" type="boolean" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="acknowledged_by" type="varchar(100)">
            </column>
            <column name="acknowledged_at" type="timestamp">
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="timestamp">
            </column>
        </createTable>

        <!-- Crew Members Table -->
        <createTable tableName="crew_members">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(50)" defaultValue="CREW">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_login" type="timestamp">
            </column>
        </createTable>

        <!-- Create indexes for performance -->
        <createIndex tableName="sensors" indexName="idx_sensors_aircraft_id">
            <column name="aircraft_id"/>
        </createIndex>

        <createIndex tableName="detected_devices" indexName="idx_devices_aircraft_id">
            <column name="aircraft_id"/>
        </createIndex>

        <createIndex tableName="detected_devices" indexName="idx_devices_sensor_id">
            <column name="sensor_id"/>
        </createIndex>

        <createIndex tableName="detected_devices" indexName="idx_devices_mac_address">
            <column name="mac_address"/>
        </createIndex>

        <createIndex tableName="detected_devices" indexName="idx_devices_last_seen">
            <column name="last_seen"/>
        </createIndex>

        <createIndex tableName="cabin_activity" indexName="idx_activity_aircraft_id">
            <column name="aircraft_id"/>
        </createIndex>

        <createIndex tableName="cabin_activity" indexName="idx_activity_row">
            <column name="row_number"/>
        </createIndex>

        <createIndex tableName="alerts" indexName="idx_alerts_aircraft_id">
            <column name="aircraft_id"/>
        </createIndex>

        <createIndex tableName="alerts" indexName="idx_alerts_active">
            <column name="is_active"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
